{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "version": 2,
    "installCommand": "npm install --omit=dev",
    "builds": [
      { "src": "server.js", "use": "@vercel/node" },
      { "src": "public/**", "use": "@vercel/static" }
    ],
    "routes": [
      { "src": "/merge", "dest": "/server.js" },
      { "src": "/(.*)", "dest": "/public/$1" }
    ]
  }
  
